// ============================================================
// Schema Prisma — Sistema de Ventas e Inventario
// Basado en: diseno_base_datos.md (conversación bbe19b28)
// Motor: PostgreSQL 16 | Esquema: pos_system
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CATÁLOGO
// ============================================================

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  products    Product[]

  @@map("categories")
}

model Size {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(20)
  sortOrder Int       @default(0) @map("sort_order")
  variants  Variant[]

  @@map("sizes")
}

model Color {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(50)
  hexCode  String    @default("#000000") @map("hex_code") @db.Char(7)
  variants Variant[]

  @@map("colors")
}

// ============================================================
// SEGURIDAD — Roles y Usuarios
// ============================================================

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(50)
  description String? @db.Text
  permissions Json    @default("{}")
  users       User[]

  @@map("roles")
}

model User {
  id              Int              @id @default(autoincrement())
  fullName        String           @map("full_name") @db.VarChar(200)
  username        String           @unique @db.VarChar(50)
  passwordHash    String           @map("password_hash") @db.VarChar(255)
  roleId          Int              @map("role_id")
  status          String           @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  lastLogin       DateTime?        @map("last_login") @db.Timestamptz()
  role            Role             @relation(fields: [roleId], references: [id])
  sales           Sale[]
  inventoryEntries InventoryEntry[]
  cashClosings    CashClosing[]
  auditLogs       AuditLog[]
  taxConfigs      TaxConfig[]

  @@map("users")
}

// ============================================================
// CATÁLOGO DE PRODUCTOS
// ============================================================

model Product {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(200)
  description String?           @db.Text
  categoryId  Int               @map("category_id")
  barcode     String?           @unique @db.VarChar(50)
  basePrice   Decimal           @map("base_price") @db.Decimal(10, 2)
  status      String            @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  category    Category          @relation(fields: [categoryId], references: [id])
  variants    Variant[]
  suppliers   ProductSupplier[]

  @@map("products")
}

model Variant {
  id            Int            @id @default(autoincrement())
  productId     Int            @map("product_id")
  sizeId        Int            @map("size_id")
  colorId       Int            @map("color_id")
  sku           String         @unique @db.VarChar(50)
  specificPrice Decimal?       @map("specific_price") @db.Decimal(10, 2)
  minThreshold  Int            @default(5) @map("min_threshold")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  size          Size           @relation(fields: [sizeId], references: [id])
  color         Color          @relation(fields: [colorId], references: [id])
  stock         Stock?
  saleDetails   SaleDetail[]
  entryDetails  EntryDetail[]

  @@unique([productId, sizeId, colorId])
  @@map("variants")
}

model Stock {
  id          Int      @id @default(autoincrement())
  variantId   Int      @unique @map("variant_id")
  quantity    Int      @default(0)
  lastUpdated DateTime @default(now()) @map("last_updated") @db.Timestamptz()
  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("stock")
}

// ============================================================
// PROVEEDORES
// ============================================================

model Supplier {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(200)
  contactPerson   String?           @map("contact_person") @db.VarChar(200)
  phone           String?           @db.VarChar(20)
  email           String?           @db.VarChar(150)
  address         String?           @db.Text
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  products        ProductSupplier[]
  inventoryEntries InventoryEntry[]

  @@map("suppliers")
}

model ProductSupplier {
  productId  Int      @map("product_id")
  supplierId Int      @map("supplier_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@map("product_suppliers")
}

// ============================================================
// CLIENTES
// ============================================================

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name") @db.VarChar(200)
  phone     String?  @db.VarChar(20)
  email     String?  @unique @db.VarChar(150)
  address   String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  sales     Sale[]

  @@map("customers")
}

// ============================================================
// DESCUENTOS
// ============================================================

model Discount {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  type      String   @db.VarChar(20)
  value     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  sales     Sale[]

  @@map("discounts")
}

// ============================================================
// VENTAS — Núcleo Transaccional
// ============================================================

model Sale {
  id                 Int         @id @default(autoincrement())
  saleNumber         String      @unique @map("sale_number") @db.VarChar(20)
  saleDate           DateTime    @default(now()) @map("sale_date") @db.Timestamptz()
  customerId         Int?        @map("customer_id")
  userId             Int         @map("user_id")
  discountId         Int?        @map("discount_id")
  subtotal           Decimal     @db.Decimal(12, 2)
  discountAmount     Decimal     @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  taxRate            Decimal     @default(0.1500) @map("tax_rate") @db.Decimal(5, 4)
  taxAmount          Decimal     @map("tax_amount") @db.Decimal(12, 2)
  total              Decimal     @db.Decimal(12, 2)
  status             String      @default("IN_PROGRESS") @db.VarChar(20)
  cancellationReason String?     @map("cancellation_reason") @db.Text
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  customer           Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user               User        @relation(fields: [userId], references: [id])
  discount           Discount?   @relation(fields: [discountId], references: [id], onDelete: SetNull)
  details            SaleDetail[]
  payment            Payment?
  receipts           Receipt[]

  @@map("sales")
}

model SaleDetail {
  id           Int     @id @default(autoincrement())
  saleId       Int     @map("sale_id")
  variantId    Int     @map("variant_id")
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  lineDiscount Decimal @default(0.00) @map("line_discount") @db.Decimal(10, 2)
  lineSubtotal Decimal @map("line_subtotal") @db.Decimal(12, 2)
  sale         Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant      Variant @relation(fields: [variantId], references: [id])

  @@map("sale_details")
}

model Payment {
  id          Int      @id @default(autoincrement())
  saleId      Int      @unique @map("sale_id")
  method      String   @db.VarChar(20)
  amountPaid  Decimal  @map("amount_paid") @db.Decimal(12, 2)
  changeGiven Decimal  @default(0.00) @map("change_given") @db.Decimal(12, 2)
  reference   String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Receipt {
  id            Int      @id @default(autoincrement())
  saleId        Int      @map("sale_id")
  receiptNumber String   @unique @map("receipt_number") @db.VarChar(20)
  type          String   @default("SALE") @db.VarChar(20)
  issuedAt      DateTime @default(now()) @map("issued_at") @db.Timestamptz()
  content       String?  @db.Text
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

// ============================================================
// INVENTARIO
// ============================================================

model InventoryEntry {
  id          Int           @id @default(autoincrement())
  entryNumber String        @unique @map("entry_number") @db.VarChar(20)
  supplierId  Int           @map("supplier_id")
  userId      Int           @map("user_id")
  entryDate   DateTime      @default(now()) @map("entry_date") @db.Timestamptz()
  notes       String?       @db.Text
  totalCost   Decimal       @default(0.00) @map("total_cost") @db.Decimal(12, 2)
  supplier    Supplier      @relation(fields: [supplierId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  details     EntryDetail[]

  @@map("inventory_entries")
}

model EntryDetail {
  id       Int            @id @default(autoincrement())
  entryId  Int            @map("entry_id")
  variantId Int           @map("variant_id")
  quantity Int
  unitCost Decimal        @map("unit_cost") @db.Decimal(10, 2)
  entry    InventoryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  variant  Variant        @relation(fields: [variantId], references: [id])

  @@map("entry_details")
}

// ============================================================
// CIERRE DE CAJA
// ============================================================

model CashClosing {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  openingDate         DateTime @map("opening_date") @db.Timestamptz()
  closingDate         DateTime @default(now()) @map("closing_date") @db.Timestamptz()
  initialAmount       Decimal  @default(0.00) @map("initial_amount") @db.Decimal(12, 2)
  totalCashSales      Decimal  @default(0.00) @map("total_cash_sales") @db.Decimal(12, 2)
  totalCardSales      Decimal  @default(0.00) @map("total_card_sales") @db.Decimal(12, 2)
  totalTransferSales  Decimal  @default(0.00) @map("total_transfer_sales") @db.Decimal(12, 2)
  totalCancellations  Decimal  @default(0.00) @map("total_cancellations") @db.Decimal(12, 2)
  expectedCash        Decimal  @default(0.00) @map("expected_cash") @db.Decimal(12, 2)
  countedAmount       Decimal  @map("counted_amount") @db.Decimal(12, 2)
  difference          Decimal  @db.Decimal(12, 2)
  notes               String?  @db.Text
  user                User     @relation(fields: [userId], references: [id])

  @@map("cash_closings")
}

// ============================================================
// CONFIGURACIÓN DE IMPUESTOS
// ============================================================

model TaxConfig {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  rate      Decimal  @db.Decimal(5, 4)
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  updatedBy Int?     @map("updated_by")
  user      User?    @relation(fields: [updatedBy], references: [id])

  @@map("tax_config")
}

// ============================================================
// AUDITORÍA
// ============================================================

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String   @db.VarChar(20)
  entity    String   @db.VarChar(50)
  entityId  Int?     @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
