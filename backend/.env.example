// ============================================================
// .env.example — Variables de entorno del sistema
// NUNCA subir el .env real al repositorio
// ============================================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:TuPasswordSegura@localhost:5432/pos_db?schema=pos_system"

# JWT
JWT_SECRET="cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="otra_clave_secreta_diferente_para_refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# CORS (origen permitido del frontend)
FRONTEND_URL="http://localhost:5173"

# Bcrypt
BCRYPT_ROUNDS=12
